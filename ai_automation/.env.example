# AI API Keys — at least one required
# The system uses whichever keys are present.
# With one key, that model handles generation and synthesis.
# With multiple keys, quality improves through cross-model consensus.
ANTHROPIC_API_KEY=your_anthropic_key
GOOGLE_API_KEY=your_gemini_key
GROQ_API_KEY=your_groq_key
MISTRAL_API_KEY=your_mistral_key
OPENROUTER_API_KEY=your_openrouter_key
TAVILY_API_KEY=your_tavily_key

# Local AI — fallback if no cloud keys are set (requires Ollama running)
LOCAL_AI_BASE_URL=http://localhost:11434/v1
LOCAL_AI_MODEL=minimax-m2.7:cloud
